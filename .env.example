# ── Required ──────────────────────────────────────────────────────────────────

BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuVWXyz

# Integer ID of your admin supergroup (must be a supergroup, not a basic group)
# Get it: add @RawDataBot to your group — it prints the chat ID
ADMIN_GROUP_ID=-1001234567890

# MongoDB Atlas free M0 cluster connection string
# Dashboard → Connect → Drivers → copy the string, replace <password>
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=supportbot

# Public HTTPS URL Render assigns to your web service
# Example: https://admin-support.onrender.com
# Do NOT add a trailing slash
WEBHOOK_HOST=https://your-app-name.onrender.com

# ── Optional ──────────────────────────────────────────────────────────────────

DB_NAME=supportbot

# Render injects PORT automatically — leave this unless running locally
PORT=8000

# Anti-spam: max N messages per WINDOW seconds, then COOLDOWN seconds blocked
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=60
RATE_LIMIT_COOLDOWN=300
