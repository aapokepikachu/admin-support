# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuVWXyz

# Integer ID of the admin supergroup, e.g. -1001234567890
# Get it by adding @userinfobot to your group
ADMIN_GROUP_ID=-1001234567890

# MongoDB Atlas connection string (free M0 tier)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Optional ──────────────────────────────────────────────────────────────────
DB_NAME=supportbot

# Anti-spam: max N messages per WINDOW seconds; then COOLDOWN seconds block
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=60
RATE_LIMIT_COOLDOWN=300
